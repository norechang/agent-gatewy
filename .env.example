# Gateway Configuration
PORT=3000

# Host User/Group IDs (auto-detected if not set)
#HOST_UID=1000
#HOST_GID=1000

# OpenCode Configuration Paths (optional - defaults shown)
#OPENCODE_CONFIG_PATH=$HOME/.config/opencode
#OPENCODE_DATA_PATH=$HOME/.local/share/opencode
#OPENCODE_CACHE_PATH=$HOME/.cache/opencode

# LLM Provider API Keys
# Set at least one to authenticate OpenCode server
#ANTHROPIC_API_KEY=your-key-here
#OPENAI_API_KEY=your-key-here
